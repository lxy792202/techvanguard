# TechVanguard Configuration

# DeepSeek API (兼容 OpenAI 格式)
# 注册获取: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 数据库路径
DATABASE_URL=sqlite+aiosqlite:///./techvanguard.db
CHROMA_DB_PATH=./chroma_db

# 数据源开关 (1=开启, 0=关闭)
SOURCE_ARXIV=1
SOURCE_GITHUB=1
SOURCE_HACKERNEWS=1
SOURCE_RSS=1
SOURCE_ZHIHU=0

# RSS 订阅源 (逗号分隔)
RSS_FEEDS=https://github.blog/feed/,https://news.ycombinator.com/rss

# 采集间隔 (分钟)
COLLECT_INTERVAL_MINUTES=30

# 服务器
HOST=0.0.0.0
PORT=8000
